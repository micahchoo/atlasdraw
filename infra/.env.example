# Atlasdraw — full-stack compose env (infra/docker-compose.yml).
# Copy to .env (NOT committed) and edit. Compose reads .env automatically
# when invoked from the repo root: docker compose --env-file .env -f infra/docker-compose.yml up

# ---- public-facing identity --------------------------------------------
# The hostname Caddy serves on. Caddy will provision a Let's Encrypt cert
# for this domain. For local testing, set to localhost and override the
# `tls` line in Caddyfile to `tls internal`.
PUBLIC_DOMAIN=atlas.example.com

# Email address Let's Encrypt uses for cert-renewal notifications. Mandatory
# for production. Ignored (but still required to be set) when tls internal.
ACME_EMAIL=ops@example.com

# ---- storage server ----------------------------------------------------
# pino log level. One of fatal | error | warn | info | debug | trace | silent.
LOG_LEVEL=info

# Opt-in error capture. Leave blank for ADR-0006-compliant zero-call-home
# default. See ADR-0009 for the data-flow note operators must include in
# their privacy policy when set.
SENTRY_DSN=

# Per-IP HTTP rate limit (fixed window). RATE_LIMIT_MAX requests per
# RATE_LIMIT_WINDOW_MS per client IP; /health is always exempt. Set
# RATE_LIMIT_MAX=0 to disable (e.g. when an upstream proxy throttles).
# Defaults (120 / 60000) are generous — abuse blunt, not usage shaping.
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000

# ---- realtime relay (compose profile: realtime) ------------------------
# Socket.IO CORS allow-list, comma-separated. Defaults to "*" (any origin).
# Pin to your domain once the relay is behind Caddy at the same origin, e.g.
# https://atlas.example.com
CORS_ORIGIN=*

# ---- Postgres (metadata) ----------------------------------------------
POSTGRES_USER=atlasdraw
POSTGRES_PASSWORD=changeme-postgres
POSTGRES_DB=atlasdraw

# ---- MinIO (blob storage) ---------------------------------------------
MINIO_ROOT_USER=atlasdraw
MINIO_ROOT_PASSWORD=changeme-minio-secret
