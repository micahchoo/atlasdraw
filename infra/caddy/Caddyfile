# Atlasdraw — Caddy reverse-proxy config for the full production stack.
#
# Routes:
#   /api/* → storage (Caddy strips the /api prefix; storage serves its
#            own routes at /maps, /share, /health, etc.)
#   /*     → web (atlas-app dist via nginx on port 3000)
#
# TLS: automatic via Let's Encrypt ACME (production) — operators MUST set
# ACME_EMAIL in .env. For local-host testing, override the `tls` line:
#   tls internal
# or comment out the entire `tls` directive and use http://${PUBLIC_DOMAIN}.

{$PUBLIC_DOMAIN} {
    encode zstd gzip

    handle_path /api/* {
        reverse_proxy storage:4000
    }

    handle {
        reverse_proxy web:3000
    }

    tls {$ACME_EMAIL}

    log {
        output stdout
        format json
        level INFO
    }
}
