{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vitest/globals", "node"],
    "baseUrl": ".",
    "paths": {
      "@atlasdraw/data": ["../packages/data/src/index.ts"],
      "@atlasdraw/geo": ["../packages/geo/src/index.ts"]
    }
  },
  "include": ["scenarios/**/*.ts", "fixtures/**/*.ts", "vitest.config.ts", "ci-gate.ts"]
}
