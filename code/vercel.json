{
  "public": true,
  "buildCommand": "yarn workspace @atlasdraw/atlas-app build",
  "outputDirectory": "apps/atlas-app/dist",
  "installCommand": "yarn install",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "origin"
        }
      ]
    },
    {
      "source": "/:file*.woff2",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000"
        }
      ]
    }
  ]
}
