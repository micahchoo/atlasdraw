{
  "compilerOptions": {
    "target": "ESNext",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "allowSyntheticDefaultImports": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "ignoreDeprecations": "6.0",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "emitDeclarationOnly": true,
    "paths": {
      "@atlasdraw/common": ["./common/src/index.ts"],
      "@atlasdraw/common/*": ["./common/src/*"],
      "@atlasdraw/element": ["./element/src/index.ts"],
      "@atlasdraw/element/*": ["./element/src/*"],
      "@atlasdraw/excalidraw": ["./excalidraw/index.tsx"],
      "@atlasdraw/excalidraw/*": ["./excalidraw/*"],
      "@atlasdraw/math": ["./math/src/index.ts"],
      "@atlasdraw/math/*": ["./math/src/*"],
      "@atlasdraw/utils": ["./utils/src/index.ts"],
      "@atlasdraw/utils/*": ["./utils/src/*"]
    }
  }
}
